#!/bin/bash

ROFI_THEME="$HOME/.config/rofi/power.rasi"

choice=$(printf "’Ćæ Shutdown\n’Ć× Reboot\n’åå Suspend\n’éŗ Logout\n’ĆŻ Lock" | \
    rofi -dmenu -i -p "Power" -theme "$ROFI_THEME")

case "$choice" in
    *Shutdown)
        systemctl poweroff
        ;;
    *Reboot)
        systemctl reboot
        ;;
    *Suspend)
        systemctl suspend
        ;;
    *Logout)
        hyprctl dispatch exit
        ;;
    *Lock)
        loginctl lock-session
        ;;
esac

